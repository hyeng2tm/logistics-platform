top/AppDev/workspaces/logistics-platform/frontend/src/components/common/FormFields.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/components/common/Modal.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/components/common/PageHeader.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/components/layout/Header.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/components/layout/MainLayout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/components/layout/MultiTabContext.tsx","messages":[],"suppressedMessages":[{"ruleId":"react-refresh/only-export-components","severity":1,"message":"Fast refresh only works when a file only exports components. Use a new file to share constants or functions between components.","line":83,"column":14,"nodeType":"Identifier","messageId":"namedExport","endLine":83,"endColumn":25,"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/components/layout/Sidebar.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/contexts/ModalContext.tsx","messages":[{"ruleId":"react-refresh/only-export-components","severity":1,"message":"Fast refresh only works when a file only exports components. Use a new file to share constants or functions between components.","line":25,"column":14,"nodeType":"Identifier","messageId":"namedExport","endLine":25,"endColumn":22}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { createContext, useContext, useState, ReactNode } from 'react';\nimport { X, AlertCircle, Info } from 'lucide-react';\n\ntype ModalType = 'alert' | 'confirm' | 'info';\n\ninterface ModalOptions {\n  title: string;\n  message: string;\n  type?: ModalType;\n  onConfirm?: () => void;\n  onCancel?: () => void;\n  confirmText?: string;\n  cancelText?: string;\n}\n\ninterface ModalContextType {\n  showAlert: (options: Omit<ModalOptions, 'type' | 'onCancel' | 'cancelText'>) => void;\n  showConfirm: (options: Omit<ModalOptions, 'type'>) => void;\n  showInfo: (options: Omit<ModalOptions, 'type' | 'onCancel' | 'cancelText'>) => void;\n  closeModal: () => void;\n}\n\nconst ModalContext = createContext<ModalContextType | undefined>(undefined);\n\nexport const useModal = () => {\n  const context = useContext(ModalContext);\n  if (!context) {\n    throw new Error('useModal must be used within a ModalProvider');\n  }\n  return context;\n};\n\nexport const ModalProvider: React.FC<{ children: ReactNode }> = ({ children }) => {\n  const [isOpen, setIsOpen] = useState(false);\n  const [modalOptions, setModalOptions] = useState<ModalOptions | null>(null);\n\n  const showAlert = (options: Omit<ModalOptions, 'type' | 'onCancel' | 'cancelText'>) => {\n    setModalOptions({ ...options, type: 'alert', confirmText: options.confirmText || '확인' });\n    setIsOpen(true);\n  };\n\n  const showConfirm = (options: Omit<ModalOptions, 'type'>) => {\n    setModalOptions({ \n      ...options, \n      type: 'confirm', \n      confirmText: options.confirmText || '확인',\n      cancelText: options.cancelText || '취소'\n    });\n    setIsOpen(true);\n  };\n\n  const showInfo = (options: Omit<ModalOptions, 'type' | 'onCancel' | 'cancelText'>) => {\n    setModalOptions({ ...options, type: 'info', confirmText: options.confirmText || '확인' });\n    setIsOpen(true);\n  };\n\n  const closeModal = () => {\n    setIsOpen(false);\n    setTimeout(() => setModalOptions(null), 200); // Wait for transition\n  };\n\n  const handleConfirm = () => {\n    if (modalOptions?.onConfirm) {\n      modalOptions.onConfirm();\n    }\n    closeModal();\n  };\n\n  const handleCancel = () => {\n    if (modalOptions?.onCancel) {\n      modalOptions.onCancel();\n    }\n    closeModal();\n  };\n\n  return (\n    <ModalContext.Provider value={{ showAlert, showConfirm, showInfo, closeModal }}>\n      {children}\n      \n      {isOpen && modalOptions && (\n        <div className=\"modal-overlay\" onClick={handleCancel}>\n          <div className=\"modal-content fade-in\" onClick={e => e.stopPropagation()}>\n            <div className=\"modal-header\">\n              <div className=\"modal-title-container\">\n                {modalOptions.type === 'alert' && <AlertCircle size={24} color=\"var(--status-danger)\" />}\n                {modalOptions.type === 'info' && <Info size={24} color=\"var(--accent-blue)\" />}\n                {modalOptions.type === 'confirm' && <AlertCircle size={24} color=\"var(--status-warning)\" />}\n                <h3 className=\"modal-title\">{modalOptions.title}</h3>\n              </div>\n              <button className=\"modal-close\" onClick={handleCancel} title=\"Close modal\" aria-label=\"Close modal\">\n                <X size={20} />\n              </button>\n            </div>\n            \n            <div className=\"modal-body\">\n              {modalOptions.message}\n            </div>\n            \n            <div className=\"modal-footer\">\n              {modalOptions.type === 'confirm' && (\n                <button className=\"btn btn-outline\" onClick={handleCancel}>\n                  {modalOptions.cancelText}\n                </button>\n              )}\n              <button \n                className={`btn ${modalOptions.type === 'alert' ? 'btn-danger' : 'btn-primary'}`} \n                onClick={handleConfirm}\n              >\n                {modalOptions.confirmText}\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n    </ModalContext.Provider>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/hooks/useDeviceDetect.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/i18n.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/main.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/pages/Callback.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/pages/Dashboard/Dashboard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/pages/dispatch/Allocation.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/pages/dispatch/Routing.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'apiClient' is defined but never used.","line":7,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":7,"endColumn":19,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"apiClient"},"fix":{"range":[416,467],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'index' is defined but never used.","line":234,"column":55,"nodeType":"Identifier","messageId":"unusedVar","endLine":234,"endColumn":60}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useEffect } from 'react';\nimport { PageHeader } from '../../components/common/PageHeader';\nimport { Card } from '../../components/common/Card';\nimport { DataTable, Column } from '../../components/common/DataTable';\nimport { InputField, SelectField } from '../../components/common/FormFields';\nimport { Search, Map as MapIcon, RotateCw, Flag, CheckCircle2, Navigation } from 'lucide-react';\nimport { apiClient } from '../../utils/apiClient';\nimport { useModal } from '../../contexts/ModalContext';\n\n// Mock Interfaces\ninterface RouteData {\n  id: number;\n  vehicleNumber: string;\n  driverName: string;\n  assignedOrderCount: number;\n  routeStatus: 'waiting' | 'in_transit' | 'completed';\n  departureTime?: string;\n  arrivalTime?: string;\n  currentLocation?: string;\n}\n\ninterface StopData {\n    orderNumber: string;\n    destination: string;\n    clientName: string;\n    status: 'pending' | 'arrived' | 'unloaded';\n    sequence: number;\n}\n\nconst Routing: React.FC = () => {\n    const { showAlert, showInfo } = useModal();\n    const [routes, setRoutes] = useState<RouteData[]>([]);\n    const [loading, setLoading] = useState(true);\n    const [selectedRoute, setSelectedRoute] = useState<RouteData | null>(null);\n    const [stops, setStops] = useState<StopData[]>([]);\n\n    const fetchRoutes = async () => {\n        setLoading(true);\n        try {\n            // Mock API response until dispatch backend is built\n            // const data = await apiClient.get<RouteData[]>('/api/v1/dispatch/routes');\n            setRoutes([\n                { id: 1, vehicleNumber: '서울 81자 1234', driverName: '김기사', assignedOrderCount: 3, routeStatus: 'in_transit', departureTime: '08:00', currentLocation: '경기도 용인시 기흥구' },\n                { id: 2, vehicleNumber: '경기 92바 5678', driverName: '이운전', assignedOrderCount: 1, routeStatus: 'waiting' },\n                { id: 3, vehicleNumber: '인천 33사 9012', driverName: '박물류', assignedOrderCount: 5, routeStatus: 'completed', departureTime: '06:30', arrivalTime: '14:20' },\n            ]);\n        } catch (error) {\n            console.error(\"Error fetching routes:\", error);\n            setRoutes([]);\n        } finally {\n            setLoading(false);\n        }\n    };\n\n    useEffect(() => {\n        fetchRoutes();\n    }, []);\n\n    const fetchStops = (routeId: number) => {\n        // Mock data fetch for a specific route's stops\n        const mockStops: Record<number, StopData[]> = {\n            1: [\n                { sequence: 1, orderNumber: 'ORD-1001', clientName: 'A물산', destination: '경기도 화성시 동탄', status: 'unloaded' },\n                { sequence: 2, orderNumber: 'ORD-1004', clientName: 'B유통', destination: '경기도 용인시 처인구', status: 'arrived' },\n                { sequence: 3, orderNumber: 'ORD-1005', clientName: 'C산업', destination: '경기도 평택시 고덕', status: 'pending' },\n            ],\n            2: [\n                { sequence: 1, orderNumber: 'ORD-1009', clientName: 'D컴퍼니', destination: '서울 강서구 마곡', status: 'pending' },\n            ],\n            3: [\n                { sequence: 1, orderNumber: 'ORD-0991', clientName: 'A물산', destination: '인천 연수구 송도', status: 'unloaded' },\n                { sequence: 2, orderNumber: 'ORD-0992', clientName: 'E상사', destination: '인천 남동구', status: 'unloaded' },\n                { sequence: 3, orderNumber: 'ORD-0994', clientName: 'F물류', destination: '부천 오정구', status: 'unloaded' },\n                { sequence: 4, orderNumber: 'ORD-0997', clientName: 'G산업', destination: '서울 구로구', status: 'unloaded' },\n                { sequence: 5, orderNumber: 'ORD-0998', clientName: 'H유통', destination: '서울 영등포구', status: 'unloaded' },\n            ]\n        };\n        setStops(mockStops[routeId] || []);\n    };\n\n    const handleSelectRoute = (row: RouteData) => {\n        setSelectedRoute(row);\n        fetchStops(row.id);\n    };\n\n    const handleOptimizeRoute = () => {\n        if (!selectedRoute || selectedRoute.routeStatus === 'completed') {\n            showAlert({ title: '최적화 불가', message: '최적화를 실행할 배차 노선을 선택해주세요. (완료된 노선 제외)' });\n            return;\n        }\n\n        // Simulate API call for Route Optimization (e.g. TSP logic)\n        showAlert({ title: '경로 최적화 진행', message: 'AI 라우팅 엔진이 최적의 경유 순서를 계산합니다.\\n(잠시만 기다려주세요.)' });\n        \n        setTimeout(() => {\n            // Mock re-ordering array randomly to simulate optimization\n            const optimized = [...stops].sort(() => Math.random() - 0.5)\n              .map((s, idx) => ({ ...s, sequence: idx + 1 }));\n            \n            setStops(optimized);\n            showInfo({ title: '최적화 완료', message: '효율적인 배송 순서로 재배치되었습니다. 저장 후 반영됩니다.' });\n        }, 1500);\n    };\n\n    const getStatusStyle = (status: string) => {\n        switch(status) {\n            case 'waiting': return { bg: '#F8FAFC', text: '#64748B', label: '대기중' };\n            case 'in_transit': return { bg: '#E0F2FE', text: '#0284C7', label: '운행중' };\n            case 'completed': return { bg: '#E6F9F4', text: '#05CD99', label: '운행종료' };\n            default: return { bg: '#F1F5F9', text: '#475569', label: status };\n        }\n    };\n\n    const columns: Column<RouteData>[] = [\n        { header: '차량 번호', accessor: 'vehicleNumber', width: '130px' },\n        { header: '담당 기사', accessor: 'driverName', width: '100px' },\n        { header: '배정 건수', accessor: (row) => `${row.assignedOrderCount}건`, width: '100px', align: 'center' },\n        { \n            header: '운행 상태', \n            accessor: (row) => {\n                const s = getStatusStyle(row.routeStatus);\n                return (\n                    <span style={{\n                        padding: '4px 8px', borderRadius: '4px', fontSize: '0.85rem', fontWeight: 600,\n                        backgroundColor: s.bg, color: s.text\n                    }}>\n                        {s.label}\n                    </span>\n                 );\n            }, \n            width: '120px', \n            align: 'center' \n        },\n        { header: '출발 현황', accessor: (row) => row.departureTime || '-', width: '100px', align: 'center' },\n        { \n            header: '관리', \n            accessor: (row) => (\n                <button \n                  className=\"btn btn-outline\" \n                  style={{ padding: '6px 12px', fontSize: '0.8rem' }}\n                  onClick={() => handleSelectRoute(row)}>\n                    노선 상세조회\n                </button>\n            ), \n            width: '120px',\n            align: 'center'\n        },\n    ];\n\n    return (\n        <div className=\"template-page fade-in\">\n            <PageHeader\n                title=\"배송 라우팅(노선) 설정\"\n                description=\"할당된 차량의 배송 경유지와 최적 배송 순서를 설정 및 모니터링합니다.\"\n                breadcrumbs={['배송 관리', '배송 라우팅']}\n            />\n\n            <div style={{ display: 'grid', gridTemplateColumns: 'minmax(0, 1fr) 450px', gap: '24px', alignItems: 'start' }}>\n                {/* Left side: Route Status List */}\n                <div style={{ display: 'flex', flexDirection: 'column', gap: '24px' }}>\n                    <Card title=\"차량 배차 및 운행 목록\">\n                        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(150px, 1fr))', gap: '16px', marginBottom: '16px' }}>\n                             <InputField label=\"차량/기사명 검색\" placeholder=\"검색어 입력...\" style={{ marginBottom: 0 }} />\n                             <SelectField\n                                 label=\"운행 상태 상태\"\n                                 options={[\n                                     { value: '', label: '전체 보기' },\n                                     { value: 'waiting', label: '대기중' },\n                                     { value: 'in_transit', label: '운행중' },\n                                     { value: 'completed', label: '운행종료' },\n                                 ]}\n                                 style={{ marginBottom: 0 }}\n                             />\n                             <button className=\"btn btn-primary\" style={{ padding: '12px 16px', height: '43px', marginTop: 'auto' }} onClick={fetchRoutes}>\n                                 <Search size={18} /> 조회\n                             </button>\n                        </div>\n\n                        {loading ? (\n                            <div style={{ padding: '40px', textAlign: 'center', color: 'var(--text-secondary)' }}>운행 노선 데이터를 불러오는 중입니다...</div>\n                        ) : (\n                            <div style={{ border: '1px solid var(--border-color)', borderRadius: '8px', overflow: 'hidden' }}>\n                                <DataTable columns={columns} data={routes} />\n                            </div>\n                        )}\n                    </Card>\n                </div>\n\n                {/* Right side: Route Detail Map/Stops */}\n                <div style={{ display: 'flex', flexDirection: 'column', gap: '24px', position: 'sticky', top: '24px' }}>\n                    <Card \n                        title=\"운행 노선 상세 및 경유지\" \n                        actions={\n                            <div style={{ display: 'flex', gap: '8px' }}>\n                               <button \n                                 className=\"btn btn-text text-primary\" \n                                 style={{ padding: '4px 8px', fontSize: '0.9rem' }}\n                                 onClick={handleOptimizeRoute}\n                                 disabled={!selectedRoute || selectedRoute.routeStatus === 'completed'}\n                               >\n                                  <RotateCw size={16} style={{ marginRight: '6px' }} /> 순서 최적화\n                               </button>\n                            </div>\n                        }\n                    >\n                        {!selectedRoute ? (\n                            <div style={{ padding: '40px 16px', textAlign: 'center', color: 'var(--text-tertiary)', display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '12px' }}>\n                                <MapIcon size={48} color=\"#E2E8F0\" />\n                                <span>좌측 목록에서 운행 노선을 선택하시면 상세 정보가 표시됩니다.</span>\n                            </div>\n                        ) : (\n                            <div className=\"route-detail-panel fade-in\">\n                                <div style={{ padding: '16px', background: '#F8FAFC', borderRadius: '8px', marginBottom: '16px', border: '1px solid var(--border-color)' }}>\n                                    <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '8px' }}>\n                                        <h4 style={{ margin: 0, fontSize: '1.1rem', color: 'var(--text-primary)', display: 'flex', alignItems: 'center', gap: '8px' }}>\n                                            <Navigation size={18} color=\"var(--accent-blue)\" /> {selectedRoute.vehicleNumber} ({selectedRoute.driverName})\n                                        </h4>\n                                        <span style={getStatusStyle(selectedRoute.routeStatus) as React.CSSProperties & { padding: '4px 8px', borderRadius: '4px', fontSize:'0.8rem', fontWeight: 600 }}>\n                                            {getStatusStyle(selectedRoute.routeStatus).label}\n                                        </span>\n                                    </div>\n                                    <div style={{ color: 'var(--text-secondary)', fontSize: '0.9rem' }}>\n                                        <strong>현재위치:</strong> {selectedRoute.currentLocation || '정보 없음'}\n                                    </div>\n                                </div>\n\n                                <div className=\"stops-timeline\" style={{ position: 'relative', paddingLeft: '16px', marginLeft: '8px', borderLeft: '2px solid var(--border-color)', display: 'flex', flexDirection: 'column', gap: '24px' }}>\n                                    <div style={{ position: 'absolute', top: -10, left: -6, background: '#fff' }}>\n                                         <Flag size={14} color=\"#64748B\" />\n                                    </div>\n                                    \n                                    {stops.length === 0 && <div style={{ color: 'var(--text-tertiary)' }}>배정된 경유지가 없습니다.</div>}\n\n                                    {stops.map((stop, index) => (\n                                        <div key={stop.orderNumber} style={{ position: 'relative' }}>\n                                            <div style={{ position: 'absolute', left: '-25px', top: '2px', background: stop.status === 'unloaded' ? '#05CD99' : stop.status === 'arrived' ? '#0EA5E9' : '#CBD5E1', width: '16px', height: '16px', borderRadius: '50%', border: '3px solid #FFF', zIndex: 1 }}></div>\n                                            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>\n                                                <div>\n                                                    <span style={{ fontSize: '0.8rem', fontWeight: 700, color: 'var(--accent-blue)', display: 'block', marginBottom: '4px' }}>경유지 {stop.sequence}</span>\n                                                    <div style={{ fontSize: '1rem', fontWeight: 600, color: 'var(--text-primary)', marginBottom: '4px' }}>{stop.clientName}</div>\n                                                    <div style={{ fontSize: '0.9rem', color: 'var(--text-secondary)' }}>{stop.destination}</div>\n                                                    <div style={{ fontSize: '0.8rem', color: 'var(--text-tertiary)', marginTop: '4px' }}>{stop.orderNumber}</div>\n                                                </div>\n                                                <div>\n                                                    {stop.status === 'unloaded' && <span style={{ display: 'flex', alignItems: 'center', gap: '4px', color: '#05CD99', fontSize: '0.8rem', fontWeight: 600 }}><CheckCircle2 size={14} /> 하차완료</span>}\n                                                    {stop.status === 'arrived' && <span style={{ color: '#0EA5E9', fontSize: '0.8rem', fontWeight: 600 }}>도착(작업중)</span>}\n                                                    {stop.status === 'pending' && <span style={{ color: '#94A3B8', fontSize: '0.8rem', fontWeight: 600 }}>예정</span>}\n                                                </div>\n                                            </div>\n                                        </div>\n                                    ))}\n\n                                    <div style={{ position: 'absolute', bottom: -10, left: -6, background: '#fff' }}>\n                                         <Flag size={14} color=\"#64748B\" />\n                                    </div>\n                                </div>\n                            </div>\n                        )}\n                    </Card>\n                </div>\n            </div>\n        </div>\n    );\n};\n\nexport default Routing;\n","usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/pages/inventory/Inbound.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'Box' is defined but never used.","line":6,"column":37,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":40,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Box"},"fix":{"range":[353,358],"text":""},"desc":"Remove unused variable \"Box\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'AlertCircle' is defined but never used.","line":6,"column":42,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":53,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"AlertCircle"},"fix":{"range":[358,371],"text":""},"desc":"Remove unused variable \"AlertCircle\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'CheckCircle2' is defined but never used.","line":6,"column":55,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":67,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"CheckCircle2"},"fix":{"range":[371,385],"text":""},"desc":"Remove unused variable \"CheckCircle2\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'apiClient' is defined but never used.","line":7,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":7,"endColumn":19,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"apiClient"},"fix":{"range":[409,460],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'willComplete' is assigned a value but never used.","line":76,"column":15,"nodeType":"Identifier","messageId":"unusedVar","endLine":76,"endColumn":27},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":96,"column":33,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":96,"endColumn":36,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[4506,4509],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[4506,4509],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":6,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useEffect } from 'react';\nimport { PageHeader } from '../../components/common/PageHeader';\nimport { Card } from '../../components/common/Card';\nimport { DataTable, Column } from '../../components/common/DataTable';\nimport { InputField, SelectField } from '../../components/common/FormFields';\nimport { Search, Save, PackagePlus, Box, AlertCircle, CheckCircle2 } from 'lucide-react';\nimport { apiClient } from '../../utils/apiClient';\nimport { useModal } from '../../contexts/ModalContext';\n\ninterface InboundData {\n  id: number;\n  inboundNumber: string;\n  clientName: string;\n  expectedDate: string;\n  itemName: string;\n  sku: string;\n  expectedQty: number;\n  receivedQty: number;\n  status: 'expected' | 'receiving' | 'completed' | 'discrepancy';\n}\n\nconst Inbound: React.FC = () => {\n    const { showAlert, showConfirm } = useModal();\n    const [inboundList, setInboundList] = useState<InboundData[]>([]);\n    const [loading, setLoading] = useState(true);\n    const [editingInbound, setEditingInbound] = useState<InboundData | null>(null);\n\n    // Form inputs for receiving\n    const [receiveInputQty, setReceiveInputQty] = useState<number>(0);\n    const [receiveLocation, setReceiveLocation] = useState<string>('');\n\n    const fetchInbound = async () => {\n        setLoading(true);\n        try {\n            // Mock API: Fetching expected and active inbound tasks\n            // const data = await apiClient.get<InboundData[]>('/api/v1/inventory/inbound');\n            setInboundList([\n                { id: 1, inboundNumber: 'IN-20231024-001', clientName: 'A물산', expectedDate: '2023-10-24', itemName: '무선 키보드 K100', sku: 'SKU-A-001', expectedQty: 500, receivedQty: 0, status: 'expected' },\n                { id: 2, inboundNumber: 'IN-20231024-002', clientName: 'B유통', expectedDate: '2023-10-24', itemName: '스마트 헤드셋 H20', sku: 'SKU-B-050', expectedQty: 200, receivedQty: 100, status: 'receiving' },\n                { id: 3, inboundNumber: 'IN-20231020-005', clientName: 'C산업', expectedDate: '2023-10-20', itemName: '산업용 장갑 M', sku: 'SKU-C-999', expectedQty: 1000, receivedQty: 1000, status: 'completed' },\n                { id: 4, inboundNumber: 'IN-20231022-001', clientName: 'D컴퍼니', expectedDate: '2023-10-22', itemName: '데스크탑 모니터 27\"', sku: 'SKU-D-027', expectedQty: 50, receivedQty: 48, status: 'discrepancy' },\n            ]);\n        } catch (error) {\n            console.error(\"Error fetching inbound:\", error);\n            setInboundList([]);\n        } finally {\n            setLoading(false);\n        }\n    };\n\n    useEffect(() => {\n        fetchInbound();\n    }, []);\n\n    const handleSelectForReceive = (row: InboundData) => {\n        if (row.status === 'completed') {\n            showAlert({ title: '안내', message: '이미 입고 완료된 항목입니다.' });\n            return;\n        }\n        setEditingInbound(row);\n        setReceiveInputQty(row.expectedQty - row.receivedQty); // Default to remaining\n        setReceiveLocation('');\n    };\n\n    const handleReceiveSubmit = async () => {\n        if (!editingInbound) return;\n        if (receiveInputQty <= 0) {\n            showAlert({ title: '입력 오류', message: '입고 수량은 1 이상이어야 합니다.' });\n            return;\n        }\n        if (!receiveLocation) {\n            showAlert({ title: '입력 오류', message: '적재 로케이션(위치)을 입력해주세요.' });\n            return;\n        }\n\n        const willComplete = editingInbound.receivedQty + receiveInputQty >= editingInbound.expectedQty;\n\n        showConfirm({\n            title: '입고 실적 등록 확인',\n            message: `[${editingInbound.itemName}] ${receiveInputQty}개를 '${receiveLocation}' 로케이션에 입고 처리하시겠습니까?`,\n            confirmText: '입고 처리',\n            onConfirm: async () => {\n                try {\n                    // await apiClient.post(`/api/v1/inventory/inbound/${editingInbound.id}/receive`, { qty: receiveInputQty, location: receiveLocation });\n                    showAlert({ title: '입고 처리 완료', message: '입고 실적이 성공적으로 반영되었습니다.' });\n                    \n                    // Mock UI update\n                    setInboundList(prev => prev.map(item => {\n                        if (item.id === editingInbound.id) {\n                            const newTotal = item.receivedQty + receiveInputQty;\n                            return { ...item, receivedQty: newTotal, status: newTotal >= item.expectedQty ? 'completed' : 'receiving' };\n                        }\n                        return item;\n                    }));\n                    setEditingInbound(null);\n                } catch (error: any) {\n                    showAlert({ title: '입고 처리 실패', message: '오류가 발생했습니다: ' + error.message });\n                }\n            }\n        });\n    };\n\n    const getStatusStyle = (status: string) => {\n        switch(status) {\n            case 'expected': return { bg: '#F8FAFC', text: '#64748B', label: '입고예정' };\n            case 'receiving': return { bg: '#E0F2FE', text: '#0284C7', label: '작업중' };\n            case 'completed': return { bg: '#E6F9F4', text: '#05CD99', label: '입고완료' };\n            case 'discrepancy': return { bg: '#FEE2E2', text: '#DC2626', label: '수량불일치' };\n            default: return { bg: '#F1F5F9', text: '#475569', label: status };\n        }\n    };\n\n    const columns: Column<InboundData>[] = [\n        { header: '입고 번호 (ASN)', accessor: 'inboundNumber', width: '140px' },\n        { header: '고객사(화주)', accessor: 'clientName', width: '120px' },\n        { header: '입고 예정일', accessor: 'expectedDate', width: '110px' },\n        { header: '상품 / 품목명', accessor: (row) => <div><div style={{ fontWeight: 600 }}>{row.itemName}</div><div style={{ fontSize: '0.8rem', color:'var(--text-tertiary)' }}>{row.sku}</div></div> },\n        { \n            header: '진행율 (수량)', \n            accessor: (row) => {\n                const percent = Math.min(100, Math.round((row.receivedQty / row.expectedQty) * 100)) || 0;\n                return (\n                    <div style={{ display: 'flex', flexDirection: 'column', gap: '4px' }}>\n                        <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: '0.85rem' }}>\n                            <span style={{ color: 'var(--accent-blue)', fontWeight: 600 }}>{row.receivedQty}</span>\n                            <span style={{ color: 'var(--text-tertiary)' }}>/ {row.expectedQty}</span>\n                        </div>\n                        <div style={{ width: '100%', height: '6px', background: '#E2E8F0', borderRadius: '3px', overflow: 'hidden' }}>\n                            <div style={{ width: `${percent}%`, height: '100%', background: percent === 100 ? '#05CD99' : 'var(--accent-blue)', transition: 'width 0.3s ease' }}></div>\n                        </div>\n                    </div>\n                );\n            }, \n            width: '150px' \n        },\n        { \n            header: '상태', \n            accessor: (row) => {\n                const s = getStatusStyle(row.status);\n                return (\n                    <span style={{ padding: '4px 8px', borderRadius: '4px', fontSize: '0.85rem', fontWeight: 600, backgroundColor: s.bg, color: s.text }}>\n                        {s.label}\n                    </span>\n                 );\n            }, \n            width: '110px', \n            align: 'center' \n        },\n        { \n            header: '관리', \n            accessor: (row) => (\n                <button \n                  className={row.status === 'completed' ? \"btn btn-outline\" : \"btn btn-primary\"} \n                  style={{ padding: '6px 12px', fontSize: '0.85rem', width: '100px' }}\n                  onClick={() => handleSelectForReceive(row)}\n                  disabled={row.status === 'completed'}\n                >\n                    {row.status === 'completed' ? '내역 보기' : '입고 작업'}\n                </button>\n            ), \n            width: '120px',\n            align: 'center'\n        },\n    ];\n\n    return (\n        <div className=\"template-page fade-in\">\n            <PageHeader\n                title=\"입고 (Inbound) 작업 관리\"\n                description=\"협력사 및 화주로부터 입고되는 상품, 자재를 검수하고 실적을 처리합니다.\"\n                breadcrumbs={['재고/WMS 관리', '입고 관리']}\n            />\n\n            {/* Inbound Working Panel */}\n            {editingInbound !== null && (\n                <Card title={<div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}><PackagePlus size={18} color=\"var(--accent-blue)\" /> 실물 입고 등록</div>} style={{ marginBottom: '24px', borderLeft: '4px solid var(--accent-blue)' }}>\n                    <div style={{ display: 'flex', flexWrap: 'wrap', gap: '24px' }}>\n                        \n                        <div style={{ flex: '1 1 300px', background: '#F8FAFC', padding: '16px', borderRadius: '8px', border: '1px solid var(--border-color)' }}>\n                            <h4 style={{ margin: '0 0 12px 0', fontSize: '0.9rem', color: 'var(--text-secondary)' }}>입고 예정 정보 (ASN)</h4>\n                            <div style={{ display: 'grid', gridTemplateColumns: '100px 1fr', gap: '8px', fontSize: '0.9rem' }}>\n                                <div style={{ color: 'var(--text-tertiary)' }}>입고 지시 번호</div>\n                                <div style={{ fontWeight: 600, color: 'var(--text-primary)' }}>{editingInbound.inboundNumber}</div>\n                                \n                                <div style={{ color: 'var(--text-tertiary)' }}>고객사</div>\n                                <div style={{ color: 'var(--text-primary)' }}>{editingInbound.clientName}</div>\n                                \n                                <div style={{ color: 'var(--text-tertiary)' }}>품목코드(SKU)</div>\n                                <div style={{ fontWeight: 600, color: 'var(--accent-blue)' }}>{editingInbound.sku}</div>\n                                \n                                <div style={{ color: 'var(--text-tertiary)' }}>품목명</div>\n                                <div style={{ color: 'var(--text-primary)' }}>{editingInbound.itemName}</div>\n                            </div>\n                        </div>\n\n                        <div style={{ flex: '2 1 400px' }}>\n                            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(180px, 1fr))', gap: '16px' }}>\n                                <InputField \n                                   label={`입고수량 등록 (잔여: ${editingInbound.expectedQty - editingInbound.receivedQty}개)`}\n                                   type=\"number\"\n                                   min={1}\n                                   value={receiveInputQty.toString()}\n                                   onChange={(v) => setReceiveInputQty(parseInt(v) || 0)}\n                                   style={{ borderColor: 'var(--accent-blue)', borderWidth: '2px' }}\n                                />\n                                <InputField \n                                   label=\"적재 로케이션 (위치 바코드)\"\n                                   value={receiveLocation}\n                                   onChange={(v) => setReceiveLocation(v)}\n                                   placeholder=\"e.g. A-01-01-01\"\n                                />\n                            </div>\n\n                            <div style={{ display: 'flex', gap: '8px', justifyContent: 'flex-end', marginTop: '24px' }}>\n                                <button className=\"btn btn-outline\" onClick={() => setEditingInbound(null)}>작업 취소</button>\n                                <button className=\"btn btn-primary\" onClick={handleReceiveSubmit} style={{ fontWeight: 600 }}>\n                                    <Save size={16} style={{ marginRight: '6px' }} /> 입고 실적 저장\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                </Card>\n            )}\n\n            <div style={{ display: 'flex', flexDirection: 'column', gap: '24px' }}>\n                <Card title=\"입고 리스트 및 지시(ASN) 현황\">\n                    <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(180px, 1fr))', gap: '16px', alignItems: 'end', marginBottom: '16px' }}>\n                         <InputField label=\"상세 검색 (품목명/입고번호)\" placeholder=\"검색어 입력...\" style={{ marginBottom: 0 }} />\n                         <SelectField\n                             label=\"화주사 단위 검색\"\n                             options={[\n                                 { value: '', label: '전체 고객사' },\n                                 { value: 'a', label: 'A물산' },\n                                 { value: 'b', label: 'B유통' },\n                             ]}\n                             style={{ marginBottom: 0 }}\n                         />\n                         <SelectField\n                             label=\"진행 상태 필터\"\n                             options={[\n                                 { value: '', label: '전체 상태' },\n                                 { value: 'expected', label: '입고 예정' },\n                                 { value: 'receiving', label: '작업 중' },\n                                 { value: 'completed', label: '입고 완료' },\n                             ]}\n                             style={{ marginBottom: 0 }}\n                         />\n                         <button className=\"btn btn-primary\" style={{ padding: '12px 16px', height: '43px' }} onClick={fetchInbound}>\n                             <Search size={18} /> 품목 검색\n                         </button>\n                    </div>\n\n                    {loading ? (\n                        <div style={{ padding: '40px', textAlign: 'center', color: 'var(--text-secondary)' }}>입고 예정 데이터를 조회중입니다...</div>\n                    ) : (\n                        <DataTable columns={columns} data={inboundList} />\n                    )}\n                </Card>\n            </div>\n        </div>\n    );\n};\n\nexport default Inbound;\n","usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/pages/inventory/Outbound.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'Truck' is defined but never used.","line":6,"column":38,"nodeType":"Identifier","messageId":"unusedVar","endLine":6,"endColumn":43,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Truck"},"fix":{"range":[354,361],"text":""},"desc":"Remove unused variable \"Truck\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'apiClient' is defined but never used.","line":7,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":7,"endColumn":19,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"apiClient"},"fix":{"range":[400,451],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'willComplete' is assigned a value but never used.","line":74,"column":15,"nodeType":"Identifier","messageId":"unusedVar","endLine":74,"endColumn":27},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":94,"column":33,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":94,"endColumn":36,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[4430,4433],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[4430,4433],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":4,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useEffect } from 'react';\nimport { PageHeader } from '../../components/common/PageHeader';\nimport { Card } from '../../components/common/Card';\nimport { DataTable, Column } from '../../components/common/DataTable';\nimport { InputField, SelectField } from '../../components/common/FormFields';\nimport { Search, Save, PackageMinus, Truck, AlertTriangle } from 'lucide-react';\nimport { apiClient } from '../../utils/apiClient';\nimport { useModal } from '../../contexts/ModalContext';\n\ninterface OutboundData {\n  id: number;\n  outboundNumber: string; // Based on Order Number usually\n  clientName: string;\n  destination: string;\n  expectedDate: string;\n  itemName: string;\n  sku: string;\n  orderQty: number;\n  pickedQty: number;\n  status: 'pending' | 'picking' | 'packed' | 'shipped' | 'shortage';\n}\n\nconst Outbound: React.FC = () => {\n    const { showAlert, showConfirm, showInfo } = useModal();\n    const [outboundList, setOutboundList] = useState<OutboundData[]>([]);\n    const [loading, setLoading] = useState(true);\n    const [editingWork, setEditingWork] = useState<OutboundData | null>(null);\n\n    // Form inputs for picking\n    const [pickInputQty, setPickInputQty] = useState<number>(0);\n\n    const fetchOutbound = async () => {\n        setLoading(true);\n        try {\n            // Mock API: Fetching picking tasks\n            // const data = await apiClient.get<OutboundData[]>('/api/v1/inventory/outbound');\n            setOutboundList([\n                { id: 1, outboundNumber: 'OUT-ORD-8821', clientName: 'A물산', destination: '서울 강남구', expectedDate: '2023-10-25', itemName: '무선 키보드 K100', sku: 'SKU-A-001', orderQty: 10, pickedQty: 0, status: 'pending' },\n                { id: 2, outboundNumber: 'OUT-ORD-8822', clientName: 'B유통', destination: '경기 성남시', expectedDate: '2023-10-25', itemName: '스마트 헤드셋 H20', sku: 'SKU-B-050', orderQty: 50, pickedQty: 25, status: 'picking' },\n                { id: 3, outboundNumber: 'OUT-ORD-8810', clientName: 'C산업', destination: '인천 연수구', expectedDate: '2023-10-24', itemName: '산업용 장갑 M', sku: 'SKU-C-999', orderQty: 100, pickedQty: 100, status: 'packed' },\n                { id: 4, outboundNumber: 'OUT-ORD-8825', clientName: 'D컴퍼니', destination: '부산 해운대구', expectedDate: '2023-10-26', itemName: '고급 복사 용지 A4', sku: 'SKU-D-100', orderQty: 500, pickedQty: 0, status: 'shortage' },\n            ]);\n        } catch (error) {\n            console.error(\"Error fetching outbound:\", error);\n            setOutboundList([]);\n        } finally {\n            setLoading(false);\n        }\n    };\n\n    useEffect(() => {\n        fetchOutbound();\n    }, []);\n\n    const handleSelectForPick = (row: OutboundData) => {\n        if (row.status === 'packed' || row.status === 'shipped') {\n            showAlert({ title: '안내', message: '피킹(출고) 작업이 이미 완료된 항목입니다.' });\n            return;\n        }\n        if (row.status === 'shortage') {\n            showInfo({ title: '결품 주의', message: '해당 출고 지시는 현재 재고 부족(결품) 상태입니다. 가용 재고를 먼저 확인하세요.' });\n        }\n        setEditingWork(row);\n        setPickInputQty(row.orderQty - row.pickedQty); // Default to remaining\n    };\n\n    const handlePickSubmit = async () => {\n        if (!editingWork) return;\n        if (pickInputQty <= 0) {\n            showAlert({ title: '입력 오류', message: '피킹(출고) 수량은 1 이상이어야 합니다.' });\n            return;\n        }\n\n        const willComplete = editingWork.pickedQty + pickInputQty >= editingWork.orderQty;\n\n        showConfirm({\n            title: '출고 실적 등록 확인',\n            message: `[${editingWork.itemName}] ${pickInputQty}개의 피킹 및 출고 포장(Packing) 작업을 완료하시겠습니까?`,\n            confirmText: '실적 등록',\n            onConfirm: async () => {\n                try {\n                    // await apiClient.post(`/api/v1/inventory/outbound/${editingWork.id}/pick`, { qty: pickInputQty });\n                    showAlert({ title: '처리 완료', message: '출고(피킹) 실적이 등록되었습니다.' });\n                    \n                    // Mock UI update\n                    setOutboundList(prev => prev.map(item => {\n                        if (item.id === editingWork.id) {\n                            const newTotal = item.pickedQty + pickInputQty;\n                            return { ...item, pickedQty: newTotal, status: newTotal >= item.orderQty ? 'packed' : 'picking' };\n                        }\n                        return item;\n                    }));\n                    setEditingWork(null);\n                } catch (error: any) {\n                    showAlert({ title: '처리 실패', message: '오류가 발생했습니다: ' + error.message });\n                }\n            }\n        });\n    };\n\n    const handleShipOut = (row: OutboundData) => {\n        showConfirm({\n            title: '상차 처리 (출하 확정)',\n            message: `선택한 주문 [${row.outboundNumber}]에 대하여 배송 차량에 상차를 확정하고 화물 출하 처리를 진행하시겠습니까?`,\n            confirmText: '출하 승인',\n            onConfirm: () => {\n                // Mock API Call here\n                showAlert({ title: '상차 완료', message: '성공적으로 상차 및 출하 지시가 완료되었습니다.' });\n                setOutboundList(prev => prev.map(item => item.id === row.id ? { ...item, status: 'shipped' } : item));\n            }\n        });\n    }\n\n    const getStatusStyle = (status: string) => {\n        switch(status) {\n            case 'pending': return { bg: '#F8FAFC', text: '#64748B', label: '출고대기' };\n            case 'picking': return { bg: '#FEF08A', text: '#A16207', label: '피킹작업중' };\n            case 'packed': return { bg: '#E0F2FE', text: '#0284C7', label: '포장완료/대기' };\n            case 'shipped': return { bg: '#E6F9F4', text: '#05CD99', label: '상차/출항' };\n            case 'shortage': return { bg: '#FEE2E2', text: '#DC2626', label: '재고부족' };\n            default: return { bg: '#F1F5F9', text: '#475569', label: status };\n        }\n    };\n\n    const columns: Column<OutboundData>[] = [\n        { header: '출고지시 번호', accessor: 'outboundNumber', width: '140px' },\n        { header: '고객사', accessor: 'clientName', width: '100px' },\n        { header: '도착지', accessor: 'destination', width: '120px' },\n        { header: '상품 / 품목명', accessor: (row) => <div><div style={{ fontWeight: 600 }}>{row.itemName}</div><div style={{ fontSize: '0.8rem', color:'var(--text-tertiary)' }}>{row.sku}</div></div> },\n        { \n            header: '피킹율 (수량)', \n            accessor: (row) => {\n                const percent = Math.min(100, Math.round((row.pickedQty / row.orderQty) * 100)) || 0;\n                return (\n                    <div style={{ display: 'flex', flexDirection: 'column', gap: '4px' }}>\n                        <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: '0.85rem' }}>\n                            <span style={{ color: 'var(--accent-blue)', fontWeight: 600 }}>{row.pickedQty}</span>\n                            <span style={{ color: 'var(--text-tertiary)' }}>/ {row.orderQty}</span>\n                        </div>\n                        <div style={{ width: '100%', height: '6px', background: '#E2E8F0', borderRadius: '3px', overflow: 'hidden' }}>\n                            <div style={{ width: `${percent}%`, height: '100%', background: percent === 100 ? '#05CD99' : '#F59E0B', transition: 'width 0.3s ease' }}></div>\n                        </div>\n                    </div>\n                );\n            }, \n            width: '150px' \n        },\n        { \n            header: '출고 상태', \n            accessor: (row) => {\n                const s = getStatusStyle(row.status);\n                return (\n                    <span style={{ padding: '4px 8px', borderRadius: '4px', fontSize: '0.85rem', fontWeight: 600, backgroundColor: s.bg, color: s.text }}>\n                        {s.label}\n                    </span>\n                 );\n            }, \n            width: '110px', \n            align: 'center' \n        },\n        { \n            header: '작업 행동', \n            accessor: (row) => (\n                <div style={{ display: 'flex', flexDirection: 'column', gap: '6px', alignItems: 'center' }}>\n                    <button \n                      className=\"btn btn-primary\" \n                      style={{ padding: '6px 12px', fontSize: '0.8rem', width: '90px' }}\n                      onClick={() => handleSelectForPick(row)}\n                      disabled={row.status === 'packed' || row.status === 'shipped'}\n                    >\n                        피킹 (Pick)\n                    </button>\n                    {(row.status === 'packed' || row.status === 'shipped') && (\n                       <button \n                         className=\"btn btn-outline\" \n                         style={{ padding: '6px 12px', fontSize: '0.8rem', width: '90px' }}\n                         onClick={() => handleShipOut(row)}\n                         disabled={row.status === 'shipped'}\n                       >\n                           상차 확정\n                       </button>\n                    )}\n                </div>\n            ), \n            width: '100px',\n            align: 'center'\n        },\n    ];\n\n    return (\n        <div className=\"template-page fade-in\">\n            <PageHeader\n                title=\"출고 지시 및 피킹 (Outbound/Picking)\"\n                description=\"주문 수집에 따른 창고 내 상품 피킹(Picking) 및 출고 패킹 작업을 처리합니다.\"\n                breadcrumbs={['재고/WMS 관리', '출고 관리']}\n            />\n\n            {/* Outbound Working Panel */}\n            {editingWork !== null && (\n                <Card title={<div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}><PackageMinus size={18} color=\"#F59E0B\" /> 출고(피킹) 실물 작업 등록</div>} style={{ marginBottom: '24px', borderLeft: '4px solid #F59E0B' }}>\n                    <div style={{ display: 'flex', flexWrap: 'wrap', gap: '24px' }}>\n                        \n                        <div style={{ flex: '1 1 300px', background: '#F8FAFC', padding: '16px', borderRadius: '8px', border: '1px solid var(--border-color)' }}>\n                            <h4 style={{ margin: '0 0 12px 0', fontSize: '0.9rem', color: 'var(--text-secondary)' }}>출고 오더 상세</h4>\n                            <div style={{ display: 'grid', gridTemplateColumns: '80px 1fr', gap: '8px', fontSize: '0.9rem' }}>\n                                <div style={{ color: 'var(--text-tertiary)' }}>지시 번호</div>\n                                <div style={{ fontWeight: 600, color: 'var(--text-primary)' }}>{editingWork.outboundNumber}</div>\n                                \n                                <div style={{ color: 'var(--text-tertiary)' }}>도착지</div>\n                                <div style={{ color: 'var(--text-primary)' }}>{editingWork.destination}</div>\n                                \n                                <div style={{ color: 'var(--text-tertiary)' }}>품목코드</div>\n                                <div style={{ fontWeight: 600, color: 'var(--accent-blue)' }}>{editingWork.sku}</div>\n                                \n                                <div style={{ color: 'var(--text-tertiary)' }}>품목명</div>\n                                <div style={{ color: 'var(--text-primary)' }}>{editingWork.itemName}</div>\n                            </div>\n                        </div>\n\n                        <div style={{ flex: '2 1 400px' }}>\n                            <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(180px, 1fr))', gap: '16px' }}>\n                                <InputField \n                                   label={`피킹/포장 작업 수량 (잔여: ${editingWork.orderQty - editingWork.pickedQty}개)`}\n                                   type=\"number\"\n                                   min={1}\n                                   value={pickInputQty.toString()}\n                                   onChange={(v) => setPickInputQty(parseInt(v) || 0)}\n                                   style={{ borderColor: '#F59E0B', borderWidth: '2px' }}\n                                />\n                                <div style={{ display: 'flex', alignItems: 'center', padding: '12px', background: '#FEF9C3', borderRadius: '8px', color: '#854D0E', fontSize: '0.9rem', marginTop: '28px', height: 'fit-content' }}>\n                                     <AlertTriangle size={18} style={{ marginRight: '8px', flexShrink: 0 }} /> 현물과 수량이 일치하는지 반드시 확인하세요.\n                                </div>\n                            </div>\n\n                            <div style={{ display: 'flex', gap: '8px', justifyContent: 'flex-end', marginTop: '24px' }}>\n                                <button className=\"btn btn-outline\" onClick={() => setEditingWork(null)}>작업 닫기</button>\n                                <button className=\"btn btn-primary\" onClick={handlePickSubmit} style={{ fontWeight: 600, backgroundColor: '#F59E0B', borderColor: '#F59E0B' }}>\n                                    <Save size={16} style={{ marginRight: '6px' }} /> 피킹 완료 처리\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                </Card>\n            )}\n\n            <div style={{ display: 'flex', flexDirection: 'column', gap: '24px' }}>\n                <Card title=\"출고 대기 (피킹 지시) 리스트\">\n                    <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(180px, 1fr))', gap: '16px', alignItems: 'end', marginBottom: '16px' }}>\n                         <InputField label=\"상세 검색 (품목명/출고번호)\" placeholder=\"검색어 입력...\" style={{ marginBottom: 0 }} />\n                         <SelectField\n                             label=\"화주(고객사)별 조회\"\n                             options={[\n                                 { value: '', label: '전체 보기' },\n                                 { value: 'a', label: 'A물산' },\n                                 { value: 'b', label: 'B유통' },\n                             ]}\n                             style={{ marginBottom: 0 }}\n                         />\n                         <SelectField\n                             label=\"작업 진행 상태\"\n                             options={[\n                                 { value: '', label: '전체 (출하완료 제외)' },\n                                 { value: 'pending', label: '피킹 대기' },\n                                 { value: 'picking', label: '피킹/작업중' },\n                                 { value: 'packed', label: '포장 완료 (상차대기)' },\n                                 { value: 'shortage', label: '재고 부족/결품' },\n                             ]}\n                             style={{ marginBottom: 0 }}\n                         />\n                         <button className=\"btn btn-primary\" style={{ padding: '12px 16px', height: '43px' }} onClick={fetchOutbound}>\n                             <Search size={18} /> 품목 검색\n                         </button>\n                    </div>\n\n                    {loading ? (\n                        <div style={{ padding: '40px', textAlign: 'center', color: 'var(--text-secondary)' }}>출고 대상 데이터를 불러오는 중입니다...</div>\n                    ) : (\n                        <DataTable columns={columns} data={outboundList} />\n                    )}\n                </Card>\n            </div>\n        </div>\n    );\n};\n\nexport default Outbound;\n","usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/pages/inventory/StockStatus.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'apiClient' is defined but never used.","line":7,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":7,"endColumn":19,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"apiClient"},"fix":{"range":[392,443],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useEffect } from 'react';\nimport { PageHeader } from '../../components/common/PageHeader';\nimport { Card } from '../../components/common/Card';\nimport { DataTable, Column } from '../../components/common/DataTable';\nimport { InputField, SelectField } from '../../components/common/FormFields';\nimport { Search, MapPin, Download, ArrowRightLeft } from 'lucide-react';\nimport { apiClient } from '../../utils/apiClient';\nimport { useModal } from '../../contexts/ModalContext';\n\ninterface StockData {\n  id: number;\n  clientName: string;\n  sku: string;\n  itemName: string;\n  category: string;\n  location: string;\n  totalQty: number;\n  availableQty: number; // Qty not tied to outbound orders\n  allocatedQty: number; // Qty tied to outbound orders\n  lastUpdated: string;\n}\n\nconst StockStatus: React.FC = () => {\n    const { showAlert, showConfirm } = useModal();\n    const [stocks, setStocks] = useState<StockData[]>([]);\n    const [loading, setLoading] = useState(true);\n\n    const fetchStocks = async () => {\n        setLoading(true);\n        try {\n            // Mock API: Fetching stock\n            // const data = await apiClient.get<StockData[]>('/api/v1/inventory/stocks');\n            setStocks([\n                { id: 1, clientName: 'A물산', sku: 'SKU-A-001', itemName: '무선 키보드 K100', category: '전자기기', location: 'A-01-01', totalQty: 1500, availableQty: 1450, allocatedQty: 50, lastUpdated: '2023-10-25 09:12' },\n                { id: 2, clientName: 'B유통', sku: 'SKU-B-050', itemName: '스마트 헤드셋 H20', category: '음향기기', location: 'B-02-12', totalQty: 300, availableQty: 250, allocatedQty: 50, lastUpdated: '2023-10-24 15:30' },\n                { id: 3, clientName: 'C산업', sku: 'SKU-C-999', itemName: '산업용 장갑 M', category: '안전용품', location: 'C-05-99', totalQty: 5000, availableQty: 5000, allocatedQty: 0, lastUpdated: '2023-10-20 11:45' },\n                { id: 4, clientName: 'D컴퍼니', sku: 'SKU-D-100', itemName: '고급 복사 용지 A4', category: '사무용품', location: 'A-03-05', totalQty: 50, availableQty: 0, allocatedQty: 50, lastUpdated: '2023-10-23 18:20' },\n                { id: 5, clientName: 'A물산', sku: 'SKU-A-002', itemName: '인체공학 마우스 M50', category: '전자기기', location: 'A-01-02', totalQty: 800, availableQty: 800, allocatedQty: 0, lastUpdated: '2023-10-25 09:15' },\n            ]);\n        } catch (error) {\n            console.error(\"Error fetching stocks:\", error);\n            setStocks([]);\n        } finally {\n            setLoading(false);\n        }\n    };\n\n    useEffect(() => {\n        fetchStocks();\n    }, []);\n\n    const handleLocationMove = (row: StockData) => {\n        // Just mock prompt for location move\n        showConfirm({\n            title: '창고/로케이션 이동',\n            message: `[${row.itemName}] 실물의 적재 위치를 현재 '${row.location}'에서 다른 곳으로 이동하시겠습니까?\\n(가용 재고: ${row.availableQty}개 한정)`,\n            confirmText: '이동 화면으로',\n            onConfirm: () => {\n                showAlert({ title: '안내', message: '로케이션 이동 및 재고 실사 기능은 다음 페이즈에 구현됩니다.' });\n            }\n        });\n    }\n\n    const getQtyColor = (available: number, allocated: number) => {\n        if (available === 0) return '#EF4444'; // Red (Out of stock)\n        if (available <= allocated) return '#F59E0B'; // Orange (Low stock relative to demand)\n        return '#10B981'; // Green (Healthy stock)\n    };\n\n    const columns: Column<StockData>[] = [\n        { header: '고객사', accessor: 'clientName', width: '100px' },\n        { header: '품목코드(SKU)', accessor: 'sku', width: '130px' },\n        { \n            header: '품목명 / 카테고리', \n            accessor: (row) => (\n                <div>\n                   <div style={{ fontWeight: 600, color: 'var(--text-primary)' }}>{row.itemName}</div>\n                   <div style={{ fontSize: '0.8rem', color: 'var(--text-tertiary)' }}>{row.category}</div>\n                </div>\n            ) \n        },\n        { \n            header: '적재 로케이션', \n            accessor: (row) => (\n                <div style={{ display: 'flex', alignItems: 'center', gap: '4px', color: 'var(--accent-blue)', fontWeight: 600 }}>\n                    <MapPin size={14} /> {row.location}\n                </div>\n            ), \n            width: '140px' \n        },\n        { \n            header: '총 재고 (Total)', \n            accessor: (row) => (\n                <span style={{ fontSize: '1.05rem', fontWeight: 600, color: 'var(--text-primary)' }}>\n                    {row.totalQty.toLocaleString()}\n                </span>\n            ), \n            align: 'right', \n            width: '120px' \n        },\n        { \n            header: '가용 재고 (Available)', \n            accessor: (row) => (\n                <span style={{ fontSize: '1.05rem', fontWeight: 700, color: getQtyColor(row.availableQty, row.allocatedQty) }}>\n                    {row.availableQty.toLocaleString()}\n                </span>\n            ), \n            align: 'right', \n            width: '140px' \n        },\n        { \n            header: '할당 재고 (Allocated)', \n            accessor: (row) => (\n                <span style={{ color: 'var(--text-tertiary)' }}>\n                    {row.allocatedQty.toLocaleString()}\n                </span>\n            ), \n            align: 'right', \n            width: '140px' \n        },\n        { header: '최근 업데이트', accessor: 'lastUpdated', width: '150px', align: 'center' },\n        { \n            header: '재고 관리', \n            accessor: (row) => (\n                <div style={{ display: 'flex', justifyContent: 'center' }}>\n                    <button \n                      className=\"btn btn-outline\" \n                      style={{ padding: '6px 12px', fontSize: '0.8rem', display: 'flex', alignItems: 'center', gap: '4px' }}\n                      onClick={() => handleLocationMove(row)}\n                    >\n                        <ArrowRightLeft size={14} /> 위치 이동\n                    </button>\n                </div>\n            ), \n            width: '120px',\n            align: 'center'\n        },\n    ];\n\n    const headerActions = (\n        <button className=\"btn btn-outline\" onClick={() => showAlert({ title: '안내', message: '현재 조회된 재고 목록을 엑셀로 다운로드합니다.' })}>\n            <Download size={18} /> 엑셀 다운로드\n        </button>\n    );\n\n    return (\n        <div className=\"template-page fade-in\">\n            <PageHeader\n                title=\"상품 재고 현황 (Status/Location)\"\n                description=\"물류 센터 내 전체 고객사의 상품 재고 수량과 위치를 실시간으로 모니터링합니다.\"\n                breadcrumbs={['재고/WMS 관리', '재고 현황']}\n                actions={headerActions}\n            />\n\n            <div style={{ display: 'flex', flexDirection: 'column', gap: '24px' }}>\n                \n                {/* Dashboard / Summary Cards */}\n                <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '24px' }}>\n                    <div className=\"stat-card\" style={{ padding: '20px', background: '#fff', border: '1px solid var(--border-color)', borderRadius: '12px', boxShadow: '0 2px 4px rgba(0,0,0,0.02)' }}>\n                        <h3 style={{ margin: '0 0 10px 0', fontSize: '0.9rem', color: 'var(--text-secondary)' }}>전체 품목 수 (SKUs)</h3>\n                        <div style={{ fontSize: '1.8rem', fontWeight: 700, color: 'var(--text-primary)' }}>{stocks.length.toLocaleString()}</div>\n                    </div>\n                    <div className=\"stat-card\" style={{ padding: '20px', background: '#fff', border: '1px solid var(--border-color)', borderRadius: '12px', boxShadow: '0 2px 4px rgba(0,0,0,0.02)' }}>\n                        <h3 style={{ margin: '0 0 10px 0', fontSize: '0.9rem', color: 'var(--text-secondary)' }}>총 가용 재고 수량</h3>\n                        <div style={{ fontSize: '1.8rem', fontWeight: 700, color: '#10B981' }}>\n                            {stocks.reduce((acc, obj) => acc + obj.availableQty, 0).toLocaleString()}\n                        </div>\n                    </div>\n                    <div className=\"stat-card\" style={{ padding: '20px', background: '#fff', border: '1px solid var(--border-color)', borderRadius: '12px', boxShadow: '0 2px 4px rgba(0,0,0,0.02)' }}>\n                        <h3 style={{ margin: '0 0 10px 0', fontSize: '0.9rem', color: 'var(--text-secondary)' }}>출고 할당(예정) 수량</h3>\n                        <div style={{ fontSize: '1.8rem', fontWeight: 700, color: '#F59E0B' }}>\n                            {stocks.reduce((acc, obj) => acc + obj.allocatedQty, 0).toLocaleString()}\n                        </div>\n                    </div>\n                    <div className=\"stat-card\" style={{ padding: '20px', background: '#FEE2E2', border: '1px solid #FCA5A5', borderRadius: '12px', boxShadow: '0 2px 4px rgba(0,0,0,0.02)' }}>\n                        <h3 style={{ margin: '0 0 10px 0', fontSize: '0.9rem', color: '#B91C1C' }}>결품/재고 부족 품목</h3>\n                        <div style={{ fontSize: '1.8rem', fontWeight: 700, color: '#DC2626' }}>\n                            {stocks.filter(s => s.availableQty === 0).length}\n                        </div>\n                    </div>\n                </div>\n\n                <Card title=\"재고 조회 / 검색 필터\">\n                    <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(180px, 1fr))', gap: '16px', alignItems: 'end', marginBottom: '16px' }}>\n                         <SelectField\n                             label=\"화주(고객사)\"\n                             options={[\n                                 { value: '', label: '전체 고객사' },\n                                 { value: 'a', label: 'A물산' },\n                                 { value: 'b', label: 'B유통' },\n                                 { value: 'c', label: 'C산업' },\n                             ]}\n                             style={{ marginBottom: 0 }}\n                         />\n                         <SelectField\n                             label=\"센터/구역 (Zone)\"\n                             options={[\n                                 { value: '', label: '전체 구역' },\n                                 { value: 'A', label: 'A Zone (일반)' },\n                                 { value: 'B', label: 'B Zone (소형)' },\n                                 { value: 'C', label: 'C Zone (대형/팔레트)' },\n                             ]}\n                             style={{ marginBottom: 0 }}\n                         />\n                         <InputField label=\"품목코드(SKU) 또는 상품명\" placeholder=\"검색어 입력...\" style={{ marginBottom: 0 }} />\n                         <button className=\"btn btn-primary\" style={{ padding: '12px 16px', height: '43px' }} onClick={fetchStocks}>\n                             <Search size={18} /> 재고 검색\n                         </button>\n                    </div>\n\n                    {loading ? (\n                        <div style={{ padding: '40px', textAlign: 'center', color: 'var(--text-secondary)' }}>재고 데이터 및 위치를 파악하는 중입니다...</div>\n                    ) : (\n                        <DataTable columns={columns} data={stocks} />\n                    )}\n                </Card>\n            </div>\n        </div>\n    );\n};\n\nexport default StockStatus;\n","usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/pages/sales/ClientManagement.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":71,"column":25,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":71,"endColumn":28,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2717,2720],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2717,2720],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":87,"column":33,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":87,"endColumn":36,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[3363,3366],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[3363,3366],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useEffect } from 'react';\nimport { PageHeader } from '../../components/common/PageHeader';\nimport { Card } from '../../components/common/Card';\nimport { DataTable, Column } from '../../components/common/DataTable';\nimport { InputField, SelectField } from '../../components/common/FormFields';\nimport { Search, Plus, Save, Edit2, Trash2 } from 'lucide-react';\nimport { apiClient } from '../../utils/apiClient';\nimport { useModal } from '../../contexts/ModalContext';\n\ninterface ClientData {\n  id?: number;\n  clientCode: string;\n  clientName: string;\n  businessNumber: string;\n  managerName: string;\n  managerPhone: string;\n  managerEmail: string;\n  status: 'active' | 'inactive';\n}\n\nconst ClientManagement: React.FC = () => {\n    const { showAlert, showConfirm } = useModal();\n    const [clients, setClients] = useState<ClientData[]>([]);\n    const [loading, setLoading] = useState(true);\n    const [editingClient, setEditingClient] = useState<Partial<ClientData> | null>(null);\n    const [searchName, setSearchName] = useState('');\n\n    const fetchClients = async (nameKeyword?: string) => {\n        setLoading(true);\n        try {\n            // NOTE: URL parameters should be appended if searching\n            const url = nameKeyword ? `/api/v1/sales/clients?name=${encodeURIComponent(nameKeyword)}` : '/api/v1/sales/clients';\n            const data = await apiClient.get<ClientData[]>(url);\n            setClients(data);\n        } catch (error) {\n            console.error(\"Error fetching clients:\", error);\n            // Don't show an alert on initial load failure necessarily, maybe just set empty\n            setClients([]);\n        } finally {\n            setLoading(false);\n        }\n    };\n\n    useEffect(() => {\n        fetchClients();\n    }, []);\n\n    const handleSearch = () => {\n        fetchClients(searchName);\n    };\n\n    const handleSave = async () => {\n        if (!editingClient?.clientCode || !editingClient?.clientName) {\n            showAlert({ title: '입력 오류', message: '고객사 코드와 고객사명은 필수입니다.' });\n            return;\n        }\n\n        try {\n             if (editingClient.id) {\n               // Update\n               await apiClient.put(`/api/v1/sales/clients/${editingClient.id}`, editingClient);\n               showAlert({ title: '수정 완료', message: '고객사 정보가 수정되었습니다.' });\n             } else {\n               // Create\n               const payload = { ...editingClient, status: editingClient.status || 'active' };\n               await apiClient.post('/api/v1/sales/clients', payload);\n               showAlert({ title: '등록 완료', message: '신규 고객사가 등록되었습니다.' });\n             }\n             setEditingClient(null);\n             fetchClients();\n        } catch (error: any) {\n            showAlert({ title: '저장 실패', message: '요청 처리에 실패했습니다: ' + error.message });\n        }\n    };\n\n    const handleDelete = (row: ClientData) => {\n        if (!row.id) return;\n        showConfirm({\n            title: '고객사 삭제',\n            message: `[${row.clientName}] 고객사를 삭제하시겠습니까?\\n관련된 오더 내역이 있을 경우 실패할 수 있습니다.`,\n            confirmText: '삭제',\n            onConfirm: async () => {\n                try {\n                    await apiClient.delete(`/api/v1/sales/clients/${row.id}`);\n                    showAlert({ title: '삭제 완료', message: '고객사 정보가 삭제되었습니다.' });\n                    fetchClients();\n                } catch (error: any) {\n                    showAlert({ title: '삭제 실패', message: '삭제 처리에 실패했습니다: ' + error.message });\n                }\n            }\n        });\n    };\n\n    const columns: Column<ClientData>[] = [\n        { header: '고객사 코드', accessor: 'clientCode', width: '120px' },\n        { header: '고객사명', accessor: 'clientName' },\n        { header: '사업자번호', accessor: 'businessNumber', width: '150px' },\n        { header: '담당자', accessor: 'managerName', width: '120px' },\n        { header: '연락처', accessor: 'managerPhone', width: '150px' },\n        {\n            header: '상태',\n            accessor: (row) => (\n                <span style={{\n                    padding: '4px 8px', borderRadius: '4px', fontSize: '0.85rem', fontWeight: 600,\n                    background: row.status === 'active' ? '#E6F9F4' : '#FFF0F1',\n                    color: row.status === 'active' ? '#05CD99' : '#FF5A5F'\n                }}>\n                    {row.status === 'active' ? '정상(거래중)' : '정지(거래종료)'}\n                </span>\n            ),\n            width: '120px',\n            align: 'center'\n        },\n        {\n            header: '관리',\n            accessor: (row) => (\n                <div style={{ display: 'flex', gap: '8px', justifyContent: 'center' }}>\n                    <button className=\"pagination-btn\" title=\"정보 수정\" onClick={() => setEditingClient(row)}>\n                        <Edit2 size={16} />\n                    </button>\n                    <button className=\"pagination-btn\" title=\"고객사 삭제\" onClick={() => handleDelete(row)}>\n                        <Trash2 size={16} color=\"var(--status-danger)\" />\n                    </button>\n                </div>\n            ),\n            width: '120px',\n            align: 'center'\n        }\n    ];\n\n    const headerActions = (\n        <button className=\"btn btn-primary\" onClick={() => setEditingClient({ status: 'active' })}>\n            <Plus size={18} /> 신규 고객사 등록\n        </button>\n    );\n\n    return (\n        <div className=\"template-page fade-in\">\n            <PageHeader\n                title=\"고객사(화주) 관리\"\n                description=\"물류 서비스를 이용하는 화주 및 고객사 정보를 등록하고 관리합니다.\"\n                breadcrumbs={['영업 관리', '고객사 관리']}\n                actions={headerActions}\n            />\n\n            {/* Editor Modal / Panel */}\n            {editingClient !== null && (\n                <Card title={editingClient.id ? \"고객사 정보 수정\" : \"신규 고객사 등록\"} style={{ marginBottom: '24px', borderLeft: '4px solid var(--accent-blue)' }}>\n                    <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '16px' }}>\n                        <InputField \n                           label=\"고객사 코드 *\" \n                           value={editingClient.clientCode || ''} \n                           onChange={(v) => setEditingClient({...editingClient, clientCode: v})} \n                           placeholder=\"CST-0001\" \n                        />\n                        <InputField \n                           label=\"고객사명 *\" \n                           value={editingClient.clientName || ''} \n                           onChange={(v) => setEditingClient({...editingClient, clientName: v})} \n                           placeholder=\"(주)물류파트너즈\" \n                        />\n                        <InputField \n                           label=\"사업자번호\" \n                           value={editingClient.businessNumber || ''} \n                           onChange={(v) => setEditingClient({...editingClient, businessNumber: v})} \n                           placeholder=\"123-45-67890\" \n                        />\n                        <InputField \n                           label=\"담당자명\" \n                           value={editingClient.managerName || ''} \n                           onChange={(v) => setEditingClient({...editingClient, managerName: v})} \n                           placeholder=\"김담당\" \n                        />\n                        <InputField \n                           label=\"담당자 연락처\" \n                           value={editingClient.managerPhone || ''} \n                           onChange={(v) => setEditingClient({...editingClient, managerPhone: v})} \n                           placeholder=\"010-1234-5678\" \n                        />\n                        <InputField \n                           label=\"담당자 이메일\" \n                           value={editingClient.managerEmail || ''} \n                           onChange={(v) => setEditingClient({...editingClient, managerEmail: v})} \n                           placeholder=\"admin@partner.com\" \n                        />\n                        <SelectField\n                            label=\"거래 상태\"\n                            value={editingClient.status || 'active'}\n                            onChange={(v) => setEditingClient({...editingClient, status: v as 'active' | 'inactive'})}\n                            options={[\n                                { value: 'active', label: '정상 (거래중)' },\n                                { value: 'inactive', label: '정지 (거래종료)' }\n                            ]}\n                        />\n                    </div>\n                    <div style={{ display: 'flex', gap: '8px', justifyContent: 'flex-end', marginTop: '16px' }}>\n                        <button className=\"btn btn-outline\" onClick={() => setEditingClient(null)}>취소</button>\n                        <button className=\"btn btn-primary\" onClick={handleSave}><Save size={16} /> 저장</button>\n                    </div>\n                </Card>\n            )}\n\n            <div style={{ display: 'flex', flexDirection: 'column', gap: '24px' }}>\n                {/* Search Header */}\n                <Card title=\"검색 필터\">\n                    <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '16px', alignItems: 'end' }}>\n                        <InputField \n                           label=\"고객사명 검색\" \n                           value={searchName} \n                           onChange={(v) => setSearchName(v)} \n                           placeholder=\"이름 입력 후 엔터...\" \n                           style={{ marginBottom: 0 }} \n                        />\n                        <SelectField\n                            label=\"거래 상태\"\n                            options={[\n                                { value: '', label: '전체' },\n                                { value: 'active', label: '정상 (거래중)' },\n                                { value: 'inactive', label: '정지 (거래종료)' },\n                            ]}\n                            style={{ marginBottom: 0 }}\n                        />\n                        <button className=\"btn btn-primary\" style={{ padding: '12px 16px', height: '43px' }} onClick={handleSearch}>\n                            <Search size={18} /> 필터 적용\n                        </button>\n                    </div>\n                </Card>\n\n                {/* Data Table */}\n                <Card noPadding>\n                    <div style={{ padding: '16px 24px', borderBottom: '1px solid var(--border-color)', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>\n                        <h3 style={{ margin: 0, fontSize: '1rem', color: 'var(--text-primary)' }}>전체 고객사 목록 (<span style={{ color: 'var(--accent-blue)' }}>{clients.length}</span>)</h3>\n                    </div>\n                    {loading ? (\n                        <div style={{ padding: '24px', textAlign: 'center' }}>데이터를 불러오는 중입니다...</div>\n                    ) : (\n                        <DataTable\n                            columns={columns}\n                            data={clients}\n                        />\n                    )}\n                </Card>\n            </div>\n        </div>\n    );\n};\n\nexport default ClientManagement;\n","usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/pages/sales/OrderManagement.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":94,"column":25,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":94,"endColumn":28,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[3367,3370],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[3367,3370],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":110,"column":33,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":110,"endColumn":36,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[4014,4017],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[4014,4017],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchOrders'. Either include it or remove the dependency array.","line":69,"column":8,"nodeType":"ArrayExpression","endLine":69,"endColumn":10,"suggestions":[{"desc":"Update the dependencies array to be: [fetchOrders]","fix":{"range":[2421,2423],"text":"[fetchOrders]"}}],"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useState, useEffect } from 'react';\nimport { PageHeader } from '../../components/common/PageHeader';\nimport { Card } from '../../components/common/Card';\nimport { DataTable, Column } from '../../components/common/DataTable';\nimport { InputField, SelectField } from '../../components/common/FormFields';\nimport { Search, Plus, Save, Edit2, Trash2, Calendar } from 'lucide-react';\nimport { apiClient } from '../../utils/apiClient';\nimport { useModal } from '../../contexts/ModalContext';\n\ninterface OrderData {\n  id?: number;\n  orderNumber: string;\n  clientId: number;\n  clientName?: string; // For display\n  orderDate: string;\n  deliveryDate: string;\n  destination: string;\n  status: 'pending' | 'processing' | 'shipped' | 'delivered' | 'cancelled';\n  totalAmount: number;\n}\n\ninterface ClientOption {\n    id: number;\n    clientName: string;\n}\n\nconst OrderManagement: React.FC = () => {\n    const { showAlert, showConfirm } = useModal();\n    const [orders, setOrders] = useState<OrderData[]>([]);\n    const [clients, setClients] = useState<ClientOption[]>([]);\n    const [loading, setLoading] = useState(true);\n    const [editingOrder, setEditingOrder] = useState<Partial<OrderData> | null>(null);\n\n    // Filters\n    const [searchOrderNum, setSearchOrderNum] = useState('');\n    const [searchStatus, setSearchStatus] = useState('');\n\n    const fetchDropdownData = async () => {\n        try {\n            // Need clients list for the dropdown\n            const data = await apiClient.get<ClientOption[]>('/api/v1/sales/clients');\n            setClients(data);\n        } catch(error) {\n            console.error(\"Failed to fetch clients for dropdown\", error);\n        }\n    }\n\n    const fetchOrders = async () => {\n        setLoading(true);\n        try {\n            let url = '/api/v1/sales/orders?';\n            if (searchOrderNum) url += `orderNumber=${encodeURIComponent(searchOrderNum)}&`;\n            if (searchStatus) url += `status=${encodeURIComponent(searchStatus)}&`;\n            \n            const data = await apiClient.get<OrderData[]>(url);\n            setOrders(data);\n        } catch (error) {\n            console.error(\"Error fetching orders:\", error);\n            setOrders([]);\n        } finally {\n            setLoading(false);\n        }\n    };\n\n    useEffect(() => {\n        fetchDropdownData();\n        fetchOrders();\n    // eslint-disable-next-line react-hooks/exhaustive-deps\n    }, []);\n\n    const handleSearch = () => {\n        fetchOrders();\n    };\n\n    const handleSave = async () => {\n        if (!editingOrder?.clientId || !editingOrder?.destination || !editingOrder?.orderDate) {\n            showAlert({ title: '입력 오류', message: '고객사, 배송지, 주문일자는 필수 항목입니다.' });\n            return;\n        }\n\n        try {\n             if (editingOrder.id) {\n               // Update\n               await apiClient.put(`/api/v1/sales/orders/${editingOrder.id}`, editingOrder);\n               showAlert({ title: '수정 완료', message: '주문 정보가 수정되었습니다.' });\n             } else {\n               // Create\n               const payload = { ...editingOrder, status: editingOrder.status || 'pending' };\n               await apiClient.post('/api/v1/sales/orders', payload);\n               showAlert({ title: '등록 완료', message: '신규 주문이 등록되었습니다.' });\n             }\n             setEditingOrder(null);\n             fetchOrders();\n        } catch (error: any) {\n            showAlert({ title: '저장 실패', message: '요청 처리에 실패했습니다: ' + error.message });\n        }\n    };\n\n    const handleDelete = (row: OrderData) => {\n        if (!row.id) return;\n        showConfirm({\n            title: '주문 삭제',\n            message: `[${row.orderNumber}] 주문을 삭제하시겠습니까?\\n이미 출하가 진행중인 주문인 경우 삭제가 제한될 수 있습니다.`,\n            confirmText: '삭제',\n            onConfirm: async () => {\n                try {\n                    await apiClient.delete(`/api/v1/sales/orders/${row.id}`);\n                    showAlert({ title: '삭제 완료', message: '주문 정보가 삭제되었습니다.' });\n                    fetchOrders();\n                } catch (error: any) {\n                    showAlert({ title: '삭제 실패', message: '삭제 처리에 실패했습니다: ' + error.message });\n                }\n            }\n        });\n    };\n\n    const getStatusColor = (status: string) => {\n        switch(status) {\n            case 'pending': return { bg: '#FFF3CD', text: '#856404', label: '접수대기' };\n            case 'processing': return { bg: '#CCE5FF', text: '#004085', label: '처리중' };\n            case 'shipped': return { bg: '#E6F9F4', text: '#05CD99', label: '배송중' };\n            case 'delivered': return { bg: '#D4EDDA', text: '#155724', label: '배송완료' };\n            case 'cancelled': return { bg: '#F8D7DA', text: '#721C24', label: '주문취소' };\n            default: return { bg: '#E2E8F0', text: '#475569', label: status };\n        }\n    }\n\n    const columns: Column<OrderData>[] = [\n        { header: '주문 번호', accessor: 'orderNumber', width: '130px' },\n        { header: '주문 일자', accessor: 'orderDate', width: '120px' },\n        { header: '고객사', accessor: 'clientName' },\n        { header: '배송지', accessor: 'destination' },\n        { header: '납기 일자', accessor: 'deliveryDate', width: '120px' },\n        { header: '총 주문금액', accessor: (row) => row.totalAmount ? row.totalAmount.toLocaleString() + '원' : '-', align: 'right', width: '120px' },\n        {\n            header: '주문 상태',\n            accessor: (row) => {\n                const colors = getStatusColor(row.status);\n                return (\n                 <span style={{\n                    padding: '4px 8px', borderRadius: '4px', fontSize: '0.85rem', fontWeight: 600,\n                    backgroundColor: colors.bg, color: colors.text\n                 }}>\n                    {colors.label}\n                 </span>\n                )\n            },\n            width: '100px',\n            align: 'center'\n        },\n        {\n            header: '관리',\n            accessor: (row) => (\n                <div style={{ display: 'flex', gap: '8px', justifyContent: 'center' }}>\n                    <button className=\"pagination-btn\" title=\"정보 수정\" onClick={() => setEditingOrder(row)}>\n                        <Edit2 size={16} />\n                    </button>\n                    <button className=\"pagination-btn\" title=\"주문 삭제\" onClick={() => handleDelete(row)}>\n                        <Trash2 size={16} color=\"var(--status-danger)\" />\n                    </button>\n                </div>\n            ),\n            width: '100px',\n            align: 'center'\n        }\n    ];\n\n    const headerActions = (\n        <button className=\"btn btn-primary\" onClick={() => setEditingOrder({ status: 'pending', totalAmount: 0 })}>\n            <Plus size={18} /> 신규 주문 등록\n        </button>\n    );\n\n    return (\n        <div className=\"template-page fade-in\">\n            <PageHeader\n                title=\"주문/오더 수집 관리\"\n                description=\"화주로부터 수집된 화물 배송 지시 및 주문 내역을 관리합니다.\"\n                breadcrumbs={['영업 관리', '주문 관리']}\n                actions={headerActions}\n            />\n\n            {/* Editor Modal / Panel */}\n            {editingOrder !== null && (\n                <Card title={editingOrder.id ? \"주문 내역 수정\" : \"신규 주문 등록\"} style={{ marginBottom: '24px', borderLeft: '4px solid var(--accent-blue)' }}>\n                    <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '16px' }}>\n                        {editingOrder.id && (\n                             <InputField \n                                label=\"주문 번호\" \n                                value={editingOrder.orderNumber || ''} \n                                readOnly\n                                disabled\n                                style={{ background: '#f8fafc' }}\n                             />\n                        )}\n                        <SelectField\n                            label=\"고객사 (화주) *\"\n                            value={editingOrder.clientId?.toString() || ''}\n                            onChange={(v) => setEditingOrder({...editingOrder, clientId: parseInt(v)})}\n                            options={[\n                                { value: '', label: '고객사를 선택하세요' },\n                                ...clients.map(c => ({ value: c.id.toString(), label: c.clientName }))\n                            ]}\n                        />\n                        <InputField \n                           label=\"주문 일자 *\" \n                           type=\"date\"\n                           value={editingOrder.orderDate || ''} \n                           onChange={(v) => setEditingOrder({...editingOrder, orderDate: v})} \n                        />\n                         <InputField \n                           label=\"납품 요청 일자\" \n                           type=\"date\"\n                           value={editingOrder.deliveryDate || ''} \n                           onChange={(v) => setEditingOrder({...editingOrder, deliveryDate: v})} \n                        />\n                        <div style={{ gridColumn: '1 / -1' }}>\n                            <InputField \n                                label=\"배송 도착지 주소 *\" \n                                value={editingOrder.destination || ''} \n                                onChange={(v) => setEditingOrder({...editingOrder, destination: v})} \n                                placeholder=\"서울특별시 강남구 테헤란로 123...\" \n                            />\n                        </div>\n                        <InputField \n                           label=\"총 부과 수수료 / 금액 (원)\" \n                           type=\"number\"\n                           value={editingOrder.totalAmount?.toString() || '0'} \n                           onChange={(v) => setEditingOrder({...editingOrder, totalAmount: parseInt(v) || 0})} \n                        />\n                        <SelectField\n                            label=\"진행 상태 *\"\n                            value={editingOrder.status || 'pending'}\n                            onChange={(v) => setEditingOrder({...editingOrder, status: v as OrderData['status']})}\n                            options={[\n                                { value: 'pending', label: '접수대기' },\n                                { value: 'processing', label: '처리중 (출하/배차)' },\n                                { value: 'shipped', label: '배송중' },\n                                { value: 'delivered', label: '배송완료' },\n                                { value: 'cancelled', label: '주문취소' }\n                            ]}\n                        />\n                    </div>\n                    <div style={{ display: 'flex', gap: '8px', justifyContent: 'flex-end', marginTop: '16px' }}>\n                        <button className=\"btn btn-outline\" onClick={() => setEditingOrder(null)}>닫기</button>\n                        <button className=\"btn btn-primary\" onClick={handleSave}><Save size={16} /> 저장</button>\n                    </div>\n                </Card>\n            )}\n\n            <div style={{ display: 'flex', flexDirection: 'column', gap: '24px' }}>\n                {/* Search Header */}\n                <Card title=\"주문 내역 상세 조회/필터\">\n                    <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '16px', alignItems: 'end' }}>\n                        <InputField \n                           label=\"주문 번호 검색 (Order No.)\" \n                           value={searchOrderNum} \n                           onChange={(v) => setSearchOrderNum(v)} \n                           placeholder=\"ORD-...\" \n                           style={{ marginBottom: 0 }} \n                        />\n                        <SelectField\n                            label=\"주문 진행 상태\"\n                            options={[\n                                { value: '', label: '전체 보기' },\n                                { value: 'pending', label: '접수대기' },\n                                { value: 'processing', label: '처리중' },\n                                { value: 'shipped', label: '배송중' },\n                                { value: 'delivered', label: '배송완료' },\n                            ]}\n                            value={searchStatus}\n                            onChange={(v) => setSearchStatus(v)}\n                            style={{ marginBottom: 0 }}\n                        />\n                         <div className=\"form-group\" style={{ marginBottom: 0 }}>\n                             <label className=\"form-label\">작업 일자 구간 (추후구현)</label>\n                             <div className=\"form-input\" style={{ display: 'flex', alignItems: 'center', color: 'var(--text-tertiary)', background: '#f8fafc', cursor: 'not-allowed' }}>\n                                 <Calendar size={16} style={{ marginRight: '8px' }} /> YYYY-MM-DD ~ YYYY-MM-DD\n                             </div>\n                         </div>\n                        \n                        <button className=\"btn btn-primary\" style={{ padding: '12px 16px', height: '43px' }} onClick={handleSearch}>\n                            <Search size={18} /> 조회\n                        </button>\n                    </div>\n                </Card>\n\n                {/* Data Table */}\n                <Card noPadding>\n                    <div style={{ padding: '16px 24px', borderBottom: '1px solid var(--border-color)', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>\n                        <h3 style={{ margin: 0, fontSize: '1rem', color: 'var(--text-primary)' }}>전체 주문 목록 (<span style={{ color: 'var(--accent-blue)' }}>{orders.length}</span>)</h3>\n                    </div>\n                    {loading ? (\n                        <div style={{ padding: '24px', textAlign: 'center' }}>오더 데이터를 매핑하는 중입니다...</div>\n                    ) : (\n                        <DataTable\n                            columns={columns}\n                            data={orders}\n                        />\n                    )}\n                </Card>\n            </div>\n        </div>\n    );\n};\n\nexport default OrderManagement;\n","usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/pages/system/CodeManagement.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/hyeng2/Desktop/AppDev/workspaces/logistics-platform/frontend/src/pages/system/MenuManagement.tsx","messages":[],"sup