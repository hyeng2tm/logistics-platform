VITE_CLIENT_ID=logistics-frontend
VITE_REDIRECT_URI=http://localhost:3000/callback
VITE_SCOPES=openid profile offline_access read write
VITE_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/login
